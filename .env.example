# Gmail / Google Workspace SMTP used by src/pages/api/quote.ts (Nodemailer).
# SMTP_USER must be a real Gmail/Workspace address; SMTP_APP_PASSWORD is an
# "App Password" generated at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on that account) — never the normal
# login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ventas@velasmontenegro.com
SMTP_APP_PASSWORD=

# Where the quote-request notification email is sent. Defaults to SMTP_USER
# if left empty.
NOTIFY_EMAIL_TO=ventas@velasmontenegro.com

# Web App URL from the Google Apps Script deployment (scripts/apps-script/Code.gs)
# that appends each lead as a row in a Google Sheet. Leave empty to skip
# sheet logging (email notifications still work without it).
APPS_SCRIPT_URL=
